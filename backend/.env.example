# MongoDB Atlas connection string
# https://cloud.mongodb.com -> Connect -> Drivers -> Node
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lost-found?retryWrites=true&w=majority

# JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-32-plus-random-hex

# Token lifetime (default: 7d)
JWT_EXPIRES_IN=7d

# Allowed origin(s) for CORS, comma-separated. Use exact Vercel URL in production.
CORS_ORIGIN=http://localhost:3000

# Node environment (production on Render)
NODE_ENV=development

# Port (Render sets this automatically; locally defaults to 8080)
PORT=8080
